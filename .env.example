# =============================================================================
# Agora 环境变量模板
# 复制为 .env 后填入实际值。.env 不纳入版本控制。
# =============================================================================

# --- 日志级别 (DEBUG / INFO / WARNING / ERROR) ---
AGORA_LOG_LEVEL=INFO

# --- Model Registry：mimo（主持人 + 总结者）---
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# --- Model Registry：ant（其他参与者）---
ANT_API_KEY=
ANT_BASE_URL=https://antchat.alipay.com/v1

# --- 本地 SSE 代理（开发调试用）---
OPENAI_SSE_PROXY_API_KEY=
OPENAI_SSE_PROXY_BASE_URL=http://localhost:3030/v1

# --- 预留 ---
OPENAI_API_KEY=
